# Server
PORT=4000
NODE_ENV=development

# SQLite database file (relative to apps/server, or absolute)
DB_PATH=./data/options-trader.sqlite

# Public origin the browser hits — where the SPA is served from. After
# Google login the server 302s back here.
#   Dev (Vite on 5173):           http://localhost:5173
#   Single-port prod / Docker:    http://localhost:4000
#   Lightsail with TLS / domain:  https://your-domain
APP_ORIGIN=http://localhost:5173

# Google OAuth (required to enable login).
# 1. Create an OAuth 2.0 Client ID in Google Cloud Console (Web application).
# 2. Set the authorized redirect URI to the value below — it must match
#    APP_ORIGIN (so cookies set by the callback are visible to the SPA).
#    The Vite dev server proxies /api/* to the backend, so a 5173 URI works
#    even though the API listens on 4000.
# 3. Paste the values here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# Zerodha Kite Connect — optional; can also be set in the Settings UI.
KITE_API_KEY=
KITE_API_SECRET=

# AI advisor — optional; only the API key is required.
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
